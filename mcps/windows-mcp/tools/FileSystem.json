{
  "name": "FileSystem",
  "description": "Manages file system operations with eight modes: 'read' (read text file contents with optional line offset/limit), 'write' (create or overwrite a file, set append=True to append), 'copy' (copy file or directory to destination), 'move' (move or rename file/directory), 'delete' (delete file or directory, set recursive=True for non-empty dirs), 'list' (list directory contents with optional pattern filter), 'search' (find files matching a glob pattern), 'info' (get file/directory metadata like size, dates, type). Relative paths are resolved from the user's Desktop folder. Use absolute paths to access other locations.",
  "inputSchema": {
    "additionalProperties": false,
    "properties": {
      "mode": {
        "enum": [
          "read",
          "write",
          "copy",
          "move",
          "delete",
          "list",
          "search",
          "info"
        ],
        "type": "string"
      },
      "path": {
        "type": "string"
      },
      "destination": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "null"
          }
        ],
        "default": null
      },
      "content": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "null"
          }
        ],
        "default": null
      },
      "pattern": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "null"
          }
        ],
        "default": null
      },
      "recursive": {
        "anyOf": [
          {
            "type": "boolean"
          },
          {
            "type": "string"
          }
        ],
        "default": false
      },
      "append": {
        "anyOf": [
          {
            "type": "boolean"
          },
          {
            "type": "string"
          }
        ],
        "default": false
      },
      "overwrite": {
        "anyOf": [
          {
            "type": "boolean"
          },
          {
            "type": "string"
          }
        ],
        "default": false
      },
      "offset": {
        "anyOf": [
          {
            "type": "integer"
          },
          {
            "type": "null"
          }
        ],
        "default": null
      },
      "limit": {
        "anyOf": [
          {
            "type": "integer"
          },
          {
            "type": "null"
          }
        ],
        "default": null
      },
      "encoding": {
        "default": "utf-8",
        "type": "string"
      },
      "show_hidden": {
        "anyOf": [
          {
            "type": "boolean"
          },
          {
            "type": "string"
          }
        ],
        "default": false
      }
    },
    "required": [
      "mode",
      "path"
    ],
    "type": "object"
  }
}