{
  "name": "MultiEdit",
  "description": "Enters text into multiple input fields at specified coordinates locs=[[x,y,text], ...] or using labels=[[label,text], ...]. Provide either locs or labels.",
  "inputSchema": {
    "additionalProperties": false,
    "properties": {
      "locs": {
        "anyOf": [
          {
            "items": {
              "items": {},
              "type": "array"
            },
            "type": "array"
          },
          {
            "type": "string"
          },
          {
            "type": "null"
          }
        ],
        "default": null
      },
      "labels": {
        "anyOf": [
          {
            "items": {
              "items": {},
              "type": "array"
            },
            "type": "array"
          },
          {
            "type": "string"
          },
          {
            "type": "null"
          }
        ],
        "default": null
      }
    },
    "type": "object"
  }
}