{
  "name": "MultiSelect",
  "description": "Selects multiple items such as files, folders, or checkboxes if press_ctrl=True, or performs multiple clicks if False. Pass locs (list of coordinates) or labels (list of UI element labels/ids).",
  "inputSchema": {
    "additionalProperties": false,
    "properties": {
      "locs": {
        "anyOf": [
          {
            "items": {
              "items": {
                "type": "integer"
              },
              "type": "array"
            },
            "type": "array"
          },
          {
            "type": "string"
          },
          {
            "type": "null"
          }
        ],
        "default": null
      },
      "labels": {
        "anyOf": [
          {
            "items": {
              "type": "integer"
            },
            "type": "array"
          },
          {
            "type": "string"
          },
          {
            "type": "null"
          }
        ],
        "default": null
      },
      "press_ctrl": {
        "anyOf": [
          {
            "type": "boolean"
          },
          {
            "type": "string"
          }
        ],
        "default": true
      }
    },
    "type": "object"
  }
}