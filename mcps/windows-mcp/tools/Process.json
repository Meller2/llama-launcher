{
  "name": "Process",
  "description": "List and kill running processes. Keywords: task manager, running tasks, kill, terminate, stop process, PID, CPU, memory usage. Use mode=\"list\" to list running processes with filtering and sorting options. Use mode=\"kill\" to terminate processes by PID or name.",
  "inputSchema": {
    "additionalProperties": false,
    "properties": {
      "mode": {
        "enum": [
          "list",
          "kill"
        ],
        "type": "string"
      },
      "name": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "null"
          }
        ],
        "default": null
      },
      "pid": {
        "anyOf": [
          {
            "type": "integer"
          },
          {
            "type": "null"
          }
        ],
        "default": null
      },
      "sort_by": {
        "default": "memory",
        "enum": [
          "memory",
          "cpu",
          "name"
        ],
        "type": "string"
      },
      "limit": {
        "default": 20,
        "type": "integer"
      },
      "force": {
        "anyOf": [
          {
            "type": "boolean"
          },
          {
            "type": "string"
          }
        ],
        "default": false
      }
    },
    "required": [
      "mode"
    ],
    "type": "object"
  }
}