{
  "name": "Type",
  "description": "Types text at specified coordinates [x, y] or passing a UI element's label/id. Set clear=True to clear existing text first, False to append. Set press_enter=True to submit after typing. Set caret_position to 'start' (beginning), 'end' (end), or 'idle' (default). Provide either loc or label.",
  "inputSchema": {
    "additionalProperties": false,
    "properties": {
      "text": {
        "type": "string"
      },
      "loc": {
        "anyOf": [
          {
            "items": {
              "type": "integer"
            },
            "type": "array"
          },
          {
            "type": "string"
          },
          {
            "type": "null"
          }
        ],
        "default": null
      },
      "label": {
        "anyOf": [
          {
            "type": "integer"
          },
          {
            "type": "null"
          }
        ],
        "default": null
      },
      "clear": {
        "anyOf": [
          {
            "type": "boolean"
          },
          {
            "type": "string"
          }
        ],
        "default": false
      },
      "caret_position": {
        "default": "idle",
        "enum": [
          "start",
          "idle",
          "end"
        ],
        "type": "string"
      },
      "press_enter": {
        "anyOf": [
          {
            "type": "boolean"
          },
          {
            "type": "string"
          }
        ],
        "default": false
      }
    },
    "required": [
      "text"
    ],
    "type": "object"
  }
}