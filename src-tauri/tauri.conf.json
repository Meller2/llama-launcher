{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ggflow",
  "version": "0.4.0",
  "identifier": "com.ggflow.app",
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDZGMzBEOEM3NUJGNUM0NzMKUldSenhQVmJ4OWd3YitHdWRzL2lLYWlONGsrOGRtcEhyeXVJaDBPdVkwNHZxK1pVU2VNOVlHRTEK",
      "endpoints": [
        "https://github.com/Meller2/llama-launcher/releases/latest/download/latest.json"
      ]
    }
  },
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "GGFlow",
        "width": 1100,
        "height": 720,
        "minWidth": 920,
        "minHeight": 600,
        "decorations": false,
        "shadow": true,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' ipc: http://ipc.localhost; img-src 'self' data:; style-src 'self' 'unsafe-inline'; font-src 'self' data:; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
